# Ide-IM-Skill 桥接配置 — Discord
# 路径：~/.claude-to-im/config.env（或 CTI_HOME 指向的目录）

CTI_RUNTIME=cursor
CTI_ENABLED_CHANNELS=discord
CTI_DEFAULT_WORKDIR=/Users/chovi/workspace
CTI_DEFAULT_MODE=code

# Discord（请替换为你的真实值）
# Bot Token: https://discord.com/developers/applications → 你的应用 → Bot → Reset Token
CTI_DISCORD_BOT_TOKEN=请替换为你的 Discord Bot Token
# 至少填一项，否则机器人会拒绝所有消息：
# Allowed User IDs: Discord 设置 → 高级 → 开启开发者模式，右键用户 → 复制用户 ID
CTI_DISCORD_ALLOWED_USERS=请替换为你的 Discord 用户 ID
# 可选：限制到指定频道/服务器
# CTI_DISCORD_ALLOWED_CHANNELS=频道ID1,频道ID2
# CTI_DISCORD_ALLOWED_GUILDS=服务器ID
